# Copy to /home/<username>/kkef/.env on PythonAnywhere (Bash: cp deploy/pythonanywhere/.env.example .env)

DJANGO_SECRET_KEY=generate-a-long-random-string-here
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=<username>.pythonanywhere.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://<username>.pythonanywhere.com

# SQLite works on free tier; use PA MySQL/Postgres URLs if you upgrade
DATABASE_URL=sqlite:////home/<username>/kkef/db.sqlite3

# Free tier has no Redis — use in-memory channels (see settings)
USE_INMEMORY_CHANNELS=1
REDIS_URL=

PUBLIC_SITE_URL=https://<username>.pythonanywhere.com
SECURE_SSL_REDIRECT=0
SESSION_COOKIE_SECURE=0
CSRF_COOKIE_SECURE=0

EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
