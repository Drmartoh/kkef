# Copy to .env and adjust values
DJANGO_SECRET_KEY=change-me-in-production-use-long-random-string
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Database — use PostgreSQL in production / Docker
DATABASE_URL=postgresql://kkef:kkef_secret@db:5432/kkef_db
# For local SQLite (optional fallback): sqlite:///./db.sqlite3

REDIS_URL=redis://redis:6379/0

# Frontend / integrations
PUBLIC_SITE_URL=http://localhost:8000

GOOGLE_MAPS_API_KEY=
LEAFLET_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png

# Payments (implement keys in production)
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=

# SMS / Email / WhatsApp (wire to your providers)
SMS_API_KEY=
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@Kiambuempowermentforum.org
DONATE_INBOX_EMAIL=donate@Kiambuempowermentforum.org
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
TWILIO_WHATSAPP_FROM=

# Optional OpenAI-compatible endpoint for AI assistant features
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Security
SECURE_SSL_REDIRECT=0
SESSION_COOKIE_SECURE=0
CSRF_COOKIE_SECURE=0
